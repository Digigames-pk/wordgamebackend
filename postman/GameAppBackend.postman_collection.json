						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"User\",\n  \"email\": \"user@example.com\",\n  \"password\": \"password\",\n  \"password_confirmation\": \"password\"\n}"
						},
						"url": "{{base_url}}/api/register",
						"description": "Throttle: 10/min"
					}
				},
				{
					"name": "Login",
					"request": {
						"auth": { "type": "noauth" },
						"method": "POST",
						"header": [
							{ "key": "Accept", "value": "application/json" },
